# PostgreSQL
DATABASE_URL="postgresql://chongxin:change_me@localhost:5432/chongxin_store?schema=public"

# Public website URL. LINE Pay redirect URL must be publicly reachable over HTTPS in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin login
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string-at-least-32-characters"

# Store information
STORE_PHONE="03-0000-0000"
STORE_ADDRESS="請填入崇信電動工具門市地址"
BANK_NAME="請填入銀行名稱"
BANK_CODE="000"
BANK_ACCOUNT="00000000000000"
BANK_ACCOUNT_NAME="崇信電動工具"

# LINE Pay Online API. Use 4 for Taiwan's current EPI-compatible flow; set 3 only when your merchant account requires v3.
LINE_PAY_API_VERSION="4"
LINE_PAY_ENV="sandbox"
LINE_PAY_CHANNEL_ID=""
LINE_PAY_CHANNEL_SECRET=""
